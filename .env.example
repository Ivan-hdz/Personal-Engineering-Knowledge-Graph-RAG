# MongoDB Atlas
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/personal-rag
MONGODB_DB=personal-rag
VECTOR_INDEX_NAME=vector_index

# Provider: "ollama" (Path A, free) or "openai" (Path B)
EMBEDDING_PROVIDER=ollama
LLM_PROVIDER=ollama

# Ollama (Path A)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_EMBEDDING_MODEL=nomic-embed-text
OLLAMA_LLM_MODEL=llama3.2

# OpenAI (Path B)
OPENAI_API_KEY=
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
OPENAI_LLM_MODEL=gpt-4o-mini

# Voyage AI (optional, code embeddings)
VOYAGE_API_KEY=
VOYAGE_EMBEDDING_MODEL=voyage-code-2

# Ingestion sources
CURSOR_TRANSCRIPTS_DIR=C:\Users\honte\.cursor\projects
OBSIDIAN_VAULT_PATH=
CHATGPT_EXPORT_PATH=
JIRA_BASE_URL=
JIRA_EMAIL=
JIRA_API_TOKEN=

# Webhooks
WEBHOOK_PORT=3456
GITHUB_WEBHOOK_SECRET=
GITLAB_WEBHOOK_SECRET=

# Chunking
CHUNK_SIZE=512
CHUNK_OVERLAP=64
